# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000/api

# WebSocket Configuration
# Set to true to enable real-time updates via WebSocket
EXPO_PUBLIC_WEBSOCKET_ENABLED=false
# WebSocket server host (use your server IP for device testing, localhost for emulator)
EXPO_PUBLIC_WEBSOCKET_HOST=localhost
# WebSocket server port (default: 6001 for laravel-websockets)
EXPO_PUBLIC_WEBSOCKET_PORT=6001
# Pusher app key for Laravel Echo (must match backend PUSHER_APP_KEY)
EXPO_PUBLIC_PUSHER_APP_KEY=local-key
