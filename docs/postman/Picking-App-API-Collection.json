{
  "info": {
    "name": "Picking App API - Full Testing",
    "description": "Colección completa para testear toda la API de Picking App\n\n## Incluye:\n- Autenticación (login)\n- Órdenes de picking\n- Validación de stock en tiempo real\n- Alertas\n- Nuevos endpoints de stock\n\n## Setup:\n1. Importar colección en Postman\n2. Configurar Environment con {{base_url}} y {{token}}\n3. Ejecutar Login primero para obtener token\n4. Ejecutar demás requests en orden\n\n## IMPORTANTE:\n- Esta colección incluye el header 'Accept: application/json' globalmente\n- Esto asegura que Laravel retorne JSON en lugar de HTML",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "order_number",
      "value": "NP-12345",
      "type": "string"
    },
    {
      "key": "item_code",
      "value": "PROD-001",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.add({",
          "    key: 'Accept',",
          "    value: 'application/json'",
          "});"
        ]
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}"
      }
    ]
  },
  "item": [
    {
      "name": "1. Autenticación",
      "item": [
        {
          "name": "Login - Obtener Token",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin@picking.app\",\n    \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('token', jsonData.data.token);",
                  "    pm.test('Token almacenado correctamente', function() {",
                  "        pm.expect(jsonData.data.token).to.not.be.empty;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Me - Obtener Usuario Actual",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": ["{{base_url}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Logout - Cerrar Sesión",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Órdenes de Picking",
      "item": [
        {
          "name": "Listar Órdenes Disponibles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/orders?status=pending",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        },
        {
          "name": "Ver Detalle de Orden",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}"]
            }
          }
        },
        {
          "name": "Iniciar Preparación de Orden",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}/start",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}", "start"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Picking de Items",
      "item": [
        {
          "name": "Marcar Item como Pickeado",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}/items/{{item_code}}/pick",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}", "items", "{{item_code}}", "pick"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"quantity\": 5\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Picking exitoso', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "pm.test('Respuesta incluye información de validación', function() {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data.validation) {",
                  "        pm.expect(jsonData.data.validation.type).to.not.be.undefined;",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Error - Marcar más de lo Pedido (OverPick)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}/items/{{item_code}}/pick",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}", "items", "{{item_code}}", "pick"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"quantity\": 999\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Retorna error 400 por OverPick', function() {",
                  "    pm.expect(pm.response.code).to.be(400);",
                  "});",
                  "",
                  "pm.test('Error code es OVER_PICK', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error.error_code).to.be('OVER_PICK');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Completar Orden",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}/complete",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}", "complete"]
            }
          }
        }
      ]
    },
    {
      "name": "4. Validación de Stock (NUEVO)",
      "item": [
        {
          "name": "Obtener Stock de Item",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}/stock/{{item_code}}",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}", "stock", "{{item_code}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Stock obtenido correctamente', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Obtener Estado de Validaciones",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}/stock-validations",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}", "stock-validations"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Validaciones obtenidas', function() {",
                  "    pm.expect(pm.response.code).to.be(200);",
                  "});",
                  "",
                  "pm.test('Respuesta tiene estructura correcta', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5. Alertas",
      "item": [
        {
          "name": "Crear Alerta",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/picking/alerts",
              "host": ["{{base_url}}"],
              "path": ["picking", "alerts"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"order_number\": \"{{order_number}}\",\n    \"item_code\": \"{{item_code}}\",\n    \"type\": \"stock_insufficient\",\n    \"message\": \"Producto sin stock suficiente en depósito\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Alerta creada correctamente', function() {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Listar Alertas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/alerts",
              "host": ["{{base_url}}"],
              "path": ["picking", "alerts"]
            }
          }
        },
        {
          "name": "Listar Alertas No Resueltas",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/alerts?resolved=false",
              "host": ["{{base_url}}"],
              "path": ["picking", "alerts"],
              "query": [
                {
                  "key": "resolved",
                  "value": "false"
                }
              ]
            }
          }
        },
        {
          "name": "Resolver Alerta",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{base_url}}/picking/alerts/1/resolve",
              "host": ["{{base_url}}"],
              "path": ["picking", "alerts", "1", "resolve"]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"resolution_notes\": \"Stock reponido en depósito\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "6. Depósitos (Warehouses)",
      "item": [
        {
          "name": "Listar Depósitos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/warehouses",
              "host": ["{{base_url}}"],
              "path": ["warehouses"]
            }
          }
        }
      ]
    },
    {
      "name": "7. Tests de Error",
      "item": [
        {
          "name": "401 - Sin Autenticación",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/orders",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Retorna 401 sin token', function() {",
                  "    pm.expect(pm.response.code).to.be(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "404 - Orden No Encontrada",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/picking/orders/NP-INVALID-99999",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "NP-INVALID-99999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Retorna 404 para orden inexistente', function() {",
                  "    pm.expect(pm.response.code).to.be(404);",
                  "});",
                  "",
                  "pm.test('Error code es ORDER_NOT_FOUND', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error.error_code).to.be('ORDER_NOT_FOUND');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "400 - Estado de Orden Inválido",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/picking/orders/{{order_number}}/start",
              "host": ["{{base_url}}"],
              "path": ["picking", "orders", "{{order_number}}", "start"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Retorna 400 si orden ya iniciada', function() {",
                  "    pm.expect(pm.response.code).to.be(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "8. Flujo Completo (E2E)",
      "item": [
        {
          "name": "E2E - Flujo Completo de Picking",
          "item": [
            {
              "name": "Paso 1: Login",
              "request": {
                "method": "POST",
                "url": {
                  "raw": "{{base_url}}/auth/login",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "login"]
                },
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"username\": \"admin@picking.app\",\n    \"password\": \"password123\"\n}"
                }
              }
            },
            {
              "name": "Paso 2: Listar Órdenes",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/picking/orders?status=pending",
                  "host": ["{{base_url}}"],
                  "path": ["picking", "orders"],
                  "query": [
                    {
                      "key": "status",
                      "value": "pending"
                    }
                  ]
                }
              }
            },
            {
              "name": "Paso 3: Ver Detalle",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/picking/orders/{{order_number}}",
                  "host": ["{{base_url}}"],
                  "path": ["picking", "orders", "{{order_number}}"]
                }
              }
            },
            {
              "name": "Paso 4: Iniciar Orden",
              "request": {
                "method": "POST",
                "url": {
                  "raw": "{{base_url}}/picking/orders/{{order_number}}/start",
                  "host": ["{{base_url}}"],
                  "path": ["picking", "orders", "{{order_number}}", "start"]
                }
              }
            },
            {
              "name": "Paso 5: Verificar Stock (NUEVO)",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/picking/orders/{{order_number}}/stock/{{item_code}}",
                  "host": ["{{base_url}}"],
                  "path": ["picking", "orders", "{{order_number}}", "stock", "{{item_code}}"]
                }
              }
            },
            {
              "name": "Paso 6: Pickear Item",
              "request": {
                "method": "POST",
                "url": {
                  "raw": "{{base_url}}/picking/orders/{{order_number}}/items/{{item_code}}/pick",
                  "host": ["{{base_url}}"],
                  "path": ["picking", "orders", "{{order_number}}", "items", "{{item_code}}", "pick"]
                },
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n    \"quantity\": 5\n}"
                }
              }
            },
            {
              "name": "Paso 7: Ver Validaciones (NUEVO)",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/picking/orders/{{order_number}}/stock-validations",
                  "host": ["{{base_url}}"],
                  "path": ["picking", "orders", "{{order_number}}", "stock-validations"]
                }
              }
            },
            {
              "name": "Paso 8: Completar Orden",
              "request": {
                "method": "POST",
                "url": {
                  "raw": "{{base_url}}/picking/orders/{{order_number}}/complete",
                  "host": ["{{base_url}}"],
                  "path": ["picking", "orders", "{{order_number}}", "complete"]
                }
              }
            },
            {
              "name": "Paso 9: Logout",
              "request": {
                "method": "POST",
                "url": {
                  "raw": "{{base_url}}/auth/logout",
                  "host": ["{{base_url}}"],
                  "path": ["auth", "logout"]
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
