APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# For local XAMPP MySQL development, the default credentials are:
#   - Username: root
#   - Password: (empty/blank)
#   - Database: picking_app (create manually or via migrations)
#
# See docs/local-setup-xampp-mysql.md for detailed setup instructions.
# ============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=picking_app
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# For production, Redis is recommended:
# CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis Configuration (Required for Reverb WebSockets)
# Install Redis locally: see docs/local-websocket-setup.md
# OR use Docker: docker-compose up -d redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# For Docker Redis on Windows/Mac/Linux:
# REDIS_HOST=127.0.0.1  # Docker forwards to localhost

# ============================================================================
# BROADCASTING CONFIGURATION (Laravel Reverb)
# ============================================================================
# BROADCAST_CONNECTION defaults to 'reverb' for real-time WebSockets.
#
# For local development with WebSockets:
#   1. Install Redis (see docs/local-websocket-setup.md)
#   2. Run: php artisan reverb:install
#   3. Set BROADCAST_CONNECTION=reverb
#   4. Configure REVERB_* variables below
#
# For local development WITHOUT WebSockets (fallback):
#   Set BROADCAST_CONNECTION=log (events are logged to console)
#
# To disable broadcasting entirely:
#   Set BROADCAST_CONNECTION=null
#
# Quick start guide: See docs/local-websocket-setup.md
# ============================================================================
BROADCAST_CONNECTION=reverb

# Reverb Configuration (Local Development)
# Generate credentials with: php artisan reverb:install
REVERB_APP_ID=local
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# For production (HTTPS/WSS):
# REVERB_HOST=your-domain.com
# REVERB_PORT=443
# REVERB_SCHEME=https

# Frontend (Vite) env vars — copy these to flexxus-picking-desktop/.env:
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Mobile (Expo) env vars — copy these to flexxus-picking-mobile/app.json:
# "websocketEnabled": true,
# "websocketHost": "192.168.1.100",  // Use your computer's IP for real device
# "websocketPort": "8080",
# "pusherAppKey": "${REVERB_APP_KEY}"

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Picking Performance
# FLEXXUS_TIMEOUT=15
# PICKING_STOCK_CACHE_TTL=45
# PICKING_ORDERS_CACHE_TTL=300
# PICKING_ADMIN_ORDERS_CACHE_TTL=120
# PICKING_STOCK_VALIDATION_TTL=60
# FLEXXUS_CIRCUIT_BREAKER_THRESHOLD=5
# FLEXXUS_CIRCUIT_BREAKER_COOLDOWN=30
