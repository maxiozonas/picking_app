    {
      "name": "04 - Admin - Listar Warehouses",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{BASE_URL}}/api/admin/warehouses",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "admin", "warehouses"]
        },
        "description": "Lista todos los warehouses del sistema.\n\n**Tests validados:**\n- Status 200\n- Respuesta es array\n- NO incluye flexxus_username ni flexxus_password (seguridad)\n- Incluye has_flexxus_credentials (estado sin secretos)"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});",
              "",
              "// Test: NO expone credenciales (seguridad)",
              "pm.test(\"Does NOT expose flexxus credentials\", function () {",
              "    const jsonData = pm.response.json();",
              "    const warehouses = jsonData.data;",
              "    ",
              "    warehouses.forEach(wh => {",
              "        pm.expect(wh).to.not.have.property('flexxus_username');",
              "        pm.expect(wh).to.not.have.property('flexxus_password');",
              "        pm.expect(wh).to.not.have.property('flexxus_url');",
              "    });",
              "});",
              "",
              "// Test: Expone estado de credenciales sin secretos",
              "pm.test(\"Exposes credential status without secrets\", function () {",
              "    const jsonData = pm.response.json();",
              "    const warehouses = jsonData.data;",
              "    ",
              "    warehouses.forEach(wh => {",
              "        pm.expect(wh).to.have.property('has_flexxus_credentials');",
              "        pm.expect(typeof wh.has_flexxus_credentials).to.eql('boolean');",
              "    });",
              "});",
              "",
              "// Guardar IDs de warehouses para siguientes requests",
              "var jsonData = pm.response.json();",
              "jsonData.data.forEach(wh => {",
              "    if (wh.code === '001') pm.collectionVariables.set('warehouse_001_id', wh.id);",
              "    if (wh.code === '002') pm.collectionVariables.set('warehouse_002_id', wh.id);",
              "    if (wh.code === '004') pm.collectionVariables.set('warehouse_004_id', wh.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 - Admin - Actualizar Credenciales (Rondeau 002)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{admin_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"flexxus_url\": \"https://pruebagiliycia.procomisp.com.ar\",\n  \"flexxus_username\": \"PREPR\",\n  \"flexxus_password\": \"1234\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/admin/warehouses/{{warehouse_002_id}}/flexxus-credentials",
          "host": ["{{BASE_URL}}"],
          "path": ["api", "admin", "warehouses", "{{warehouse_002_id}}", "flexxus-credentials"]
        },
        "description": "Actualiza credenciales Flexxus del depósito Rondeau (002).\n\n**Credenciales reales:**\n- URL: https://pruebagiliycia.procomisp.com.ar\n- Username: PREPR\n- Password: 1234\n\n**Tests validados:**\n- Status 200\n- Respuesta NO incluye secretos\n- has_flexxus_credentials = true"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Test: Respuesta NO expone credenciales",
              "pm.test(\"Response does NOT expose credentials\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.not.have.property('flexxus_username');",
              "    pm.expect(jsonData).to.not.have.property('flexxus_password');",
              "    pm.expect(jsonData).to.not.have.property('flexxus_url');",
              "});",
              "",
              "// Test: Indica que tiene credenciales",
              "pm.test(\"Warehouse has credentials\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.has_flexxus_credentials).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
